<Window x:Class="EyeGuard.WarningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EyeGuard 休息提醒" Height="90" Width="180"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent">
    <Border x:Name="CardBorder" CornerRadius="12" Margin="8"
            Background="#1976D2" Padding="12,8"
            BorderThickness="0">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="12"
                              ShadowDepth="2" Direction="270"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBlock Text="⏳" FontSize="22" VerticalAlignment="Center"
                       Margin="0,0,8,0" Foreground="White"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="即将锁屏" FontSize="14" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock x:Name="CountdownText" Text="00:30" FontSize="26" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>