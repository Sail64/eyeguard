<Window x:Class="EyeGuard.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EyeGuard 设置" Height="640" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource SurfaceBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="24,20,24,0">
            <TextBlock Text="EyeGuard  设置" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock x:Name="SubtitleText" Text="初始化设置"
                       Style="{StaticResource CaptionText}" Margin="0,0,0,16"/>

            <CheckBox x:Name="AutoStartCheckBox" Content="允许开机自动启动"
                      Style="{StaticResource StyledCheckBox}" IsChecked="True" Margin="0,0,0,4"/>

            <Separator Style="{StaticResource SectionDivider}"/>

            <TextBlock Text="🔑  密码设置" Style="{StaticResource SectionTitleText}"/>
            <TextBlock x:Name="PasswordHintText" Style="{StaticResource CaptionText}" Margin="0,0,0,10"
                       Text="设置解锁密码，用于锁屏解锁和修改设置时验证身份"/>

            <TextBlock Text="密码" Style="{StaticResource LabelText}" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PasswordBox" Style="{StaticResource StyledPasswordBox}"
                         Margin="0,0,0,10"/>

            <TextBlock Text="确认密码" Style="{StaticResource LabelText}" Margin="0,0,0,4"/>
            <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource StyledPasswordBox}"
                         Margin="0,0,0,4"/>

            <Separator Style="{StaticResource SectionDivider}"/>

            <TextBlock Text="⏱  时间设置" Style="{StaticResource SectionTitleText}"/>
            <TextBlock Style="{StaticResource CaptionText}" Margin="0,0,0,10"
                       Text="调整护眼提醒周期参数"/>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="使用时长" Style="{StaticResource LabelText}"
                           VerticalAlignment="Center" Grid.Column="0" Margin="0,0,8,0"/>
                <TextBox x:Name="WorkMinutesBox" Style="{StaticResource StyledTextBox}"
                         Text="40" Grid.Column="1" Margin="0,0,8,0"
                         TextAlignment="Center"/>
                <TextBlock Text="分钟" Style="{StaticResource CaptionText}"
                           VerticalAlignment="Center" Grid.Column="2"/>
            </Grid>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="休息时长" Style="{StaticResource LabelText}"
                           VerticalAlignment="Center" Grid.Column="0" Margin="0,0,8,0"/>
                <TextBox x:Name="BreakMinutesBox" Style="{StaticResource StyledTextBox}"
                         Text="5" Grid.Column="1" Margin="0,0,8,0"
                         TextAlignment="Center"/>
                <TextBlock Text="分钟" Style="{StaticResource CaptionText}"
                           VerticalAlignment="Center" Grid.Column="2"/>
            </Grid>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="预警时长" Style="{StaticResource LabelText}"
                           VerticalAlignment="Center" Grid.Column="0" Margin="0,0,8,0"/>
                <TextBox x:Name="WarningSecondsBox" Style="{StaticResource StyledTextBox}"
                         Text="30" Grid.Column="1" Margin="0,0,8,0"
                         TextAlignment="Center"/>
                <TextBlock Text="秒" Style="{StaticResource CaptionText}"
                           VerticalAlignment="Center" Grid.Column="2"/>
            </Grid>

            <TextBlock x:Name="ErrorText" Style="{StaticResource ErrorText}"
                       Margin="0,4,0,0" Visibility="Collapsed"/>
        </StackPanel>

        <Border Grid.Row="1" Background="{StaticResource SurfaceAltBrush}" Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="SuccessBanner" Grid.Column="0"
                           Text="✓  设置已保存" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"
                           VerticalAlignment="Center" Visibility="Collapsed"/>
                <Button x:Name="SaveButton" Grid.Column="1" Content="保存设置"
                        Style="{StaticResource PrimaryButton}" Width="140"
                        Click="SaveButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>