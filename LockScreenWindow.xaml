<Window x:Class="EyeGuard.LockScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EyeGuard 锁屏" 
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        WindowStartupLocation="Manual"
        Topmost="True"
        ShowInTaskbar="False"
        Background="#0A3A6E">
    <Grid>
        <Rectangle x:Name="Gradient1"/>
        <Rectangle x:Name="Gradient2"/>
        <Rectangle x:Name="Gradient3"/>
        <Rectangle x:Name="Gradient4"/>

        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                CornerRadius="12"
                BorderBrush="#4090CAF9" BorderThickness="1.5"
                Padding="40,30">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#CC3474AE" Offset="0"/>
                    <GradientStop Color="#CC0A3A6E" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#42A5F5" BlurRadius="20" Opacity="0.3" ShadowDepth="0"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="爱护眼睛，休息片刻" FontSize="36" FontWeight="Bold" 
                           HorizontalAlignment="Center" Foreground="White" Margin="0,0,0,10"/>
                <TextBlock Text="休息时间" FontSize="18" HorizontalAlignment="Center" 
                           Foreground="#90CAF9" Margin="0,0,0,30"/>
                <TextBlock x:Name="CountdownText" Text="05:00" FontSize="120" FontWeight="Bold" 
                           HorizontalAlignment="Center" Foreground="White" Margin="0,0,0,40"/>
                <TextBlock HorizontalAlignment="Center" Margin="0,30,0,0" FontSize="13" Opacity="0.6">
                    <Hyperlink x:Name="EmergencyExitLink"
                               Click="EmergencyExit_Click"
                               Foreground="#90CAF9"
                               TextDecorations="None"
                               Cursor="Hand">
                        紧急退出
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>